javascript:(function(){const style=document.createElement('style');style.innerHTML=`
.f-modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); display: flex; justify-content: center; align-items: center; z-index: 999999; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
.f-modal-card { background: #fff; width: 90%; max-width: 500px; padding: 24px; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.3); position: relative; animation: fFadeIn 0.2s ease-out; box-sizing: border-box; }
.f-modal-title { margin: 0 0 12px 0; font-size: 20px; font-weight: bold; color: #1a1a1a; display: flex; align-items: center; gap: 8px; }
.f-modal-subtitle { font-size: 13px; color: #666; margin-bottom: 16px; line-height: 1.4; }
.f-modal-textarea { width: 100%; height: 180px; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-family: monospace; font-size: 12px; resize: none; box-sizing: border-box; outline: none; transition: border-color 0.2s; }
.f-modal-textarea:focus { border-color: #0a9f2e; }
.f-modal-footer { display: flex; justify-content: flex-end; gap: 12px; margin-top: 16px; }
.f-btn { padding: 10px 20px; border-radius: 6px; font-size: 14px; font-weight: bold; cursor: pointer; border: none; transition: background 0.2s; }
.f-btn-cancel { background: #f0f0f0; color: #444; }
.f-btn-cancel:hover { background: #e0e0e0; }
.f-btn-primary { background: #0a9f2e; color: #fff; }
.f-btn-primary:hover { background: #088526; }
@keyframes fFadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
`;document.head.appendChild(style);const overlay=document.createElement('div');overlay.className='f-modal-overlay';overlay.innerHTML=`
<div class="f-modal-card">
<h3 class="f-modal-title">⚽ Fantasy Ranking Updater</h3>
<p class="f-modal-subtitle">Cole abaixo o JSON do <strong>SNAPSHOT ANTERIOR</strong>.</p>
<textarea class="f-modal-textarea" placeholder="{&#10;  &quot;Onlyflancis&quot;: { &quot;pos&quot;: 1, &quot;pts&quot;: 935 }, ...&#10;}"></textarea>
<div class="f-modal-footer">
<button class="f-btn f-btn-cancel">Cancelar</button>
<button class="f-btn f-btn-primary">Processar e Copiar</button>
</div>
</div>
`;document.body.appendChild(overlay);const textarea=overlay.querySelector('.f-modal-textarea');const btnCancel=overlay.querySelector('.f-btn-cancel');const btnProcess=overlay.querySelector('.f-btn-primary');textarea.focus();const closeModal=()=>{overlay.remove();style.remove();};btnCancel.onclick=closeModal;overlay.onclick=(e)=>{if(e.target===overlay)closeModal();};btnProcess.onclick=()=>{let PREVIOUS_RANKING={};try{const rawText=textarea.value.trim();if(rawText){PREVIOUS_RANKING=JSON.parse(rawText);}}catch(err){alert('❌ JSON Inválido! Verifique se as chaves ou vírgulas estão corretas.');return;}document.querySelectorAll('.fantasy-added').forEach(el=>el.remove());const rows=document.querySelectorAll('tbody tr');const currentRanking={};rows.forEach(row=>{row.classList.remove('xvcJA');row.style.setProperty('background','transparent','important');row.style.setProperty('background-color','transparent','important');row.style.setProperty('border-bottom','1px solid #e6e6e6','important');row.querySelectorAll('td').forEach(td=>{td.style.setProperty('background','transparent','important');td.style.setProperty('background-color','transparent','important');});});rows.forEach(row=>{const posCell=row.querySelector('td:nth-child(1)');const userCell=row.querySelector('.username span')||row.querySelector('[class*="username"]');const ptsCell=row.querySelector('td:nth-child(3)');if(!posCell||!userCell||!ptsCell)return;const username=userCell.textContent.replace(/\\s+/g,' ').trim();let posText=posCell.textContent.replace(/[^0-9]/g,'');let pos=parseInt(posText,10)||0;let ptsText=ptsCell.textContent.replace(/[^0-9]/g,'');let pts=parseInt(ptsText,10)||0;currentRanking[username]={pos,pts};const previous=PREVIOUS_RANKING[username];let pointsDelta=0;let posDelta=0;if(previous){pointsDelta=pts-previous.pts;posDelta=previous.pos-pos;}let arrow='►';let arrowColor='#888';if(!previous){arrow='★';arrowColor='#f5a623';}else if(posDelta>0){arrow='▲';arrowColor='#0a9f2e';}else if(posDelta<0){arrow='▼';arrowColor='#d93025';}posCell.innerHTML=`<span style="display:flex; justify-content:center; align-items:center; gap:4px;"><span>${pos}</span><span style="color:${arrowColor}; font-size:11px; font-weight:bold;">${arrow}</span></span>`;ptsCell.innerHTML='';const score=document.createElement('span');score.textContent=pts;score.style.display='inline-block';score.style.width='42px';score.style.textAlign='right';ptsCell.appendChild(score);const delta=document.createElement('span');delta.className='fantasy-added';delta.style.marginLeft='8px';delta.style.fontSize='11px';let deltaColor='#888';if(pointsDelta>0)deltaColor='#0a9f2e';else if(pointsDelta<0)deltaColor='#d93025';delta.style.color=deltaColor;if(!previous)delta.textContent=`+${pts}`;else if(pointsDelta===0)delta.textContent='0';else delta.textContent=`${pointsDelta>0?'+':''}${pointsDelta}`;ptsCell.appendChild(delta);});const snapshotString=JSON.stringify(currentRanking,null,4);const clipTextarea=document.createElement('textarea');clipTextarea.value=snapshotString;clipTextarea.style.position='fixed';document.body.appendChild(clipTextarea);clipTextarea.select();try{document.execCommand('copy');}catch(err){console.log(snapshotString);}document.body.removeChild(clipTextarea);closeModal();};})();
